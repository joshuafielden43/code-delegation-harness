#!/usr/bin/env python3
"""
Professional `gcdh` command.

After cloning the repo:
    chmod +x bin/gcdh
    export PATH="$PWD/bin:$PATH"

Then just run `gcdh`.

This is currently the most reliable way to get the professional CLI experience.
`pip install -e .` also provides `gcdh` (and is improving rapidly).
"""
import sys
from pathlib import Path

repo_root = Path(__file__).parent.parent
src_dir = repo_root / "src"

if str(src_dir) not in sys.path:
    sys.path.insert(0, str(src_dir))

from grok_delegate import main

if __name__ == "__main__":
    # Make argv[0] nicer
    if sys.argv:
        sys.argv[0] = "gcdh"
    main()
