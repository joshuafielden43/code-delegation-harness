#!/bin/bash
# gcdh-tmux — robust one-command launcher for serious long-running work

set -euo pipefail

if ! command -v tmux >/dev/null 2>&1; then
    echo "[gcdh-tmux] ERROR: tmux is not installed."
    exit 1
fi

SESSION="cdh-$(date +%s)-$$"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"

# Build argument list, ensuring --long-running is present
args=("$@")
if [[ ! " ${args[*]} " =~ " --long-running " && ! " ${args[*]} " =~ " --keep-driving " ]]; then
    args=("--long-running" "${args[@]}")
fi

# Create a temporary script for the actual command.
# This is much more reliable for very long prompts than trying to pass
# a giant quoted string through tmux + shell.
TMP_SCRIPT=$(mktemp /tmp/gcdh-tmux-XXXXXX.sh)
chmod +x "$TMP_SCRIPT"

cat > "$TMP_SCRIPT" << EOF
#!/bin/bash
set -euo pipefail
cd "$REPO_ROOT"
export GCDH_IN_TMUX=1

# Prefer local venv if it exists
if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
    exec "$REPO_ROOT/.venv/bin/python" -m code_delegation_harness ${args[@]@Q}
else
    exec gcdh ${args[@]@Q}
fi
EOF

echo "[gcdh-tmux] Launching in detached tmux session: $SESSION"
tmux new-session -d -s "$SESSION" "$TMP_SCRIPT"

echo
echo "[gcdh-tmux] *** Job is now running in tmux ***"
echo "[gcdh-tmux] Session : $SESSION"
echo "[gcdh-tmux] Attach  : tmux attach -t $SESSION"
echo "[gcdh-tmux] Monitor : gcdh --status --target-dir \"$PWD\""
echo "[gcdh-tmux] (You can safely exit now.)"
echo

if [[ -t 1 ]]; then
    echo "[gcdh-tmux] Attaching now (Ctrl-b d to detach)..."
    sleep 0.5
    exec tmux attach -t "$SESSION"
fi
